{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('active').val() == true || !root.child('users').exists())",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        ".write": "auth != null && (!root.child('users').exists() || auth.uid == $uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
        "role": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'giorgio.pascali990@gmail.com' || !root.child('users').exists() || newData.val() == data.val()"
        },
        "active": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'giorgio.pascali990@gmail.com' || !root.child('users').exists() || newData.val() == data.val() || newData.val() == false"
        },
        "status": {
          ".validate": "root.child('users').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'giorgio.pascali990@gmail.com' || newData.val() == 'pending' || newData.val() == 'rejected' || newData.val() == data.val()"
        }
      }
    },

    "projects": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() == true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() == true && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'manager')",
      "$pid": {
        ".read": "auth != null && data.child('clientUid').val() == auth.uid"
      }
    },

    "tasks": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() == true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() == true && root.child('users').child(auth.uid).child('role').val() != 'cliente'"
    },

    "templates": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() == true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() == true && (root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('users').child(auth.uid).child('role').val() == 'manager')"
