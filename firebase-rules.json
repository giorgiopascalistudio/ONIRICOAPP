        "$doc": {
          ".write": "auth != null && ((root.child('users').child(auth.uid).child('active').val() == true && root.child('users').child(auth.uid).child('role').val() != 'cliente') || (root.child('projects').child($pid).child('clientUid').val() == auth.uid && !data.exists()))"
